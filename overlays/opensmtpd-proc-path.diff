index 2365b1ee..b1b6bcec 100644
--- a/usr.sbin/smtpd/smtpd.c
+++ b/usr.sbin/smtpd/smtpd.c

@@ -1387,6 +1393,7 @@ fork_filter_process(const char *name, const char *command, const char *user, con
 	int		 sp[2], errfd[2];
 	struct passwd	*pw;
 	struct group	*gr;
