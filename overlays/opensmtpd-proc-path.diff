 	char		 exec[_POSIX_ARG_MAX];
 	int		 execr;
 
@@ -1455,7 +1462,12 @@ fork_filter_process(const char *name, const char *command, const char *user, con
-	if (command[0] == '/')
-		execr = snprintf(exec, sizeof(exec), "exec %s", command);
